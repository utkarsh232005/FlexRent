<% layout("/layouts/boilerplate") %>
<div class="row mt-5">
    <div class="col-8 offset-2 text-center">
        <div class="alert alert-danger p-4 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-exclamation fa-3x text-danger mb-3"></i>
            <h2 class="alert-heading mb-3">Oops! Something went wrong</h2>
            <hr class="border-danger">
            <p class="lead mb-4"><%= err.message %></p>
            <a href="/listings" class="btn btn-danger px-4 py-2">
                <i class="fa-solid fa-house me-2"></i>Go back to Listings
            </a>
        </div>
    </div>
</div>
