<% layout("/layouts/boilerplate") %>
<div class="show-page py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <!-- Title & Location -->
            <h1 class="fw-bold mb-1" style="font-size: 1.75rem;"><%= listing.title %></h1>
            <p class="mb-3" style="color: #717171;">
                <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
            </p>

            <!-- Hero Image -->
            <div class="mb-4">
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>"
                     style="width: 100%; height: 420px; object-fit: cover; border-radius: 12px;">
            </div>

            <!-- Two Column Layout: Details + Price Sidebar -->
            <div class="row">
                <!-- Left Column: Description -->
                <div class="col-12 col-md-7 col-lg-8">
                    <div class="pb-4 mb-4" style="border-bottom: 1px solid #ebebeb;">
                        <h2 class="fw-semibold mb-2" style="font-size: 1.35rem;">About this place</h2>
                        <p style="color: #717171; line-height: 1.7; font-size: 1rem;">
                            <%= listing.description %>
                        </p>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2 pb-4 mb-4" style="border-bottom: 1px solid #ebebeb;">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark btn-sm px-3 py-2" style="border-radius: 8px;">
                            <i class="fa-solid fa-pen me-1"></i>Edit
                        </a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                            <button type="submit" class="btn btn-outline-danger btn-sm px-3 py-2" style="border-radius: 8px;">
                                <i class="fa-solid fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Right Column: Price Card -->
                <div class="col-12 col-md-5 col-lg-4">
                    <div style="border: 1px solid #dddddd; border-radius: 12px; padding: 24px; box-shadow: 0 6px 16px rgba(0,0,0,0.08); position: sticky; top: 100px;">
                        <div class="d-flex align-items-baseline gap-1 mb-3">
                            <span class="fw-bold" style="font-size: 1.5rem;">₹<%= listing.price.toLocaleString("en-IN") %></span>
                            <span style="color: #717171; font-size: 1rem;">/ night</span>
                        </div>
                        <div class="mb-3 p-3" style="background: #f7f7f7; border-radius: 8px;">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="color: #717171; font-size: 0.9rem;">Location</span>
                                <span class="fw-medium" style="font-size: 0.9rem;"><%= listing.location %></span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span style="color: #717171; font-size: 0.9rem;">Country</span>
                                <span class="fw-medium" style="font-size: 0.9rem;"><%= listing.country %></span>
                            </div>
                        </div>
                        <a href="#review-section" class="btn w-100 py-2 text-white fw-semibold" style="background: #ff385c; border-radius: 8px; border: none;">
                            <i class="fa-solid fa-star me-1"></i>Write a Review
                        </a>
                    </div>
                </div>
            </div>

            <!-- Reviews Section -->
            <div id="review-section" class="pt-2">
                <div class="pb-4 mb-4" style="border-bottom: 1px solid #ebebeb;">
                    <h2 class="fw-semibold mb-3" style="font-size: 1.35rem;">Leave a Review</h2>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label class="form-label fw-medium" style="font-size: 0.95rem;">Rating</label>
                            <div class="star-rating">
                                <input type="radio" id="star5" name="review[rating]" value="5" />
                                <label for="star5" class="fa-solid fa-star"></label>
                                <input type="radio" id="star4" name="review[rating]" value="4" />
                                <label for="star4" class="fa-solid fa-star"></label>
                                <input type="radio" id="star3" name="review[rating]" value="3" />
                                <label for="star3" class="fa-solid fa-star"></label>
                                <input type="radio" id="star2" name="review[rating]" value="2" />
                                <label for="star2" class="fa-solid fa-star"></label>
                                <input type="radio" id="star1" name="review[rating]" value="1" checked />
                                <label for="star1" class="fa-solid fa-star"></label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label fw-medium" style="font-size: 0.95rem;">Comments</label>
                            <textarea name="review[comment]" id="comment" rows="3" class="form-control" required
                                      style="border-radius: 8px; border-color: #dddddd;"></textarea>
                            <div class="invalid-feedback">Please add some comments for your review.</div>
                        </div>
                        <button class="btn btn-dark px-4 py-2" style="border-radius: 8px;">Submit Review</button>
                    </form>
                </div>

                <% if (listing.reviews.length > 0) { %>
                    <h2 class="fw-semibold mb-3" style="font-size: 1.35rem;">
                        <i class="fa-solid fa-star me-1" style="color: #ffb400;"></i><%= listing.reviews.length %> Review<%= listing.reviews.length > 1 ? 's' : '' %>
                    </h2>
                    <div class="row">
                        <% for(review of listing.reviews){ %>
                            <div class="col-12 col-md-6 mb-3">
                                <div style="padding: 20px; border: 1px solid #ebebeb; border-radius: 12px; height: 100%; display: flex; flex-direction: column; justify-content: space-between;">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <div style="width: 36px; height: 36px; border-radius: 50%; background: #222; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem;">G</div>
                                            <div>
                                                <div class="fw-semibold" style="font-size: 0.95rem;">Guest</div>
                                                <div style="color: #ffb400; font-size: 0.85rem;">
                                                    <% for(let i = 0; i < review.rating; i++) { %>★<% } %><% for(let i = review.rating; i < 5; i++) { %>☆<% } %>
                                                </div>
                                            </div>
                                        </div>
                                        <p style="color: #717171; font-size: 0.95rem; margin-bottom: 12px;"><%= review.comment %></p>
                                    </div>
                                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-0 text-end">
                                        <button class="btn btn-sm px-0 py-0" style="color: #717171; font-size: 0.8rem; text-decoration: underline; border: none; background: none;">Remove</button>
                                    </form>
                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</div>